    <!-- https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#hasAssociatedPublication -->

    <owl:DatatypeProperty rdf:about="https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#hasAssociatedPublication">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#Investigation"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#anyURI"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#string"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.w3.org/ns/ssn/systems/Conditionhttp://purl.org/ppeo/PPEO.owl#hasAssociatedPublication</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">An identifier for a literature publication where the investigation is described. Use of DOIs is recommended (In case of more than 1 use semicolon-separated format).</rdfs:label>
        <rdfs:label xml:lang="en">Associated Publication</rdfs:label>
    </owl:DatatypeProperty>
    


