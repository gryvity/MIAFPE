    <!-- https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#DataFile -->

    <owl:Class rdf:about="https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#DataFile">
        <rdfs:subClassOf rdf:nodeID="genid8"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://purl.org/ppeo/ppeo.owl#data_file</rdfs:isDefinedBy>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid8">
        <owl:onProperty rdf:resource="https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#hasIdentifier"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#anyURI"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#string"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </owl:onDataRange>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://github.com/gryvity/MIAFPE/tree/master/ontology/miappexsosa.owl#DataFile"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid8"/>
        <rdfs:comment xml:lang="en">Unique Identifier which acts as unambiguous link between Instances.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://purl.org/ppeo/ppeo.owl#hasIdentifier</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Unique Identifier</rdfs:label>
    </owl:Axiom>
    


